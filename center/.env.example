# SuperDreams Center - Environment Variables
# Copy to .env.local and fill in actual values

# ===== JWT Secret =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===== Upstash Redis (Production Persistence) =====
# When set, Center auto-switches to Upstash Redis for persistent storage
# Without these, it falls back to local SQLite (better-sqlite3)
# Create via Vercel Dashboard > Storage > Redis (Upstash)
# Also accepts legacy KV_REST_API_URL / KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Database Path (SQLite mode only) =====
# DATABASE_PATH=./data/center.db
