# SuperDreams Agent - Environment Variables
# Copy to .env.local and fill in actual values

# ===== Upstash Redis (Production Persistence) =====
# When set, Agent auto-switches to Upstash Redis for persistent storage
# Without these, it falls back to local SQLite (sql.js)
# Create via Vercel Dashboard > Storage > Redis (Upstash)
# Also accepts legacy KV_REST_API_URL / KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Center Sync (Optional) =====
# Target URL and API key for syncing to Center
# CENTER_URL=https://your-center.vercel.app
# CENTER_API_KEY=your-api-key
